>]
	E31I2fycy2 [label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
  <TR><TD BGCOLOR="#add8ff" WIDTH="150"><B>Analysis</B></TD></TR>
  <TR><TD ALIGN="left" WIDTH="150">No stock or securities were distributed<BR ALIGN='left'/>to the Roses. But despite the language<BR ALIGN='left'/>in § 368(a)(1)(D), courts have held that<BR ALIGN='left'/>a distribution of stock or securities is<BR ALIGN='left'/>not necessary where ownership of the<BR ALIGN='left'/>transferor and transferee corporations<BR ALIGN='left'/>is identical, because such a<BR ALIGN='left'/>distribution would be a mere formality.</TD></TR>
</TABLE>
>]
