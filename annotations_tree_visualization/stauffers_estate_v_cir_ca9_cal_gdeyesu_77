	NdKMkQgZRY [label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
  <TR><TD BGCOLOR="#add8ff" WIDTH="150"><B>Analysis</B></TD></TR>
  <TR><TD ALIGN="left" WIDTH="150">The &quot;F&quot; reorganization is defined in §<BR ALIGN='left'/>368(a) (1) as &quot;a mere change in<BR ALIGN='left'/>identity, form, or place of<BR ALIGN='left'/>organization, however 616*616 effected,&quot;<BR ALIGN='left'/>and is not further defined in the<BR ALIGN='left'/>regulations. There is a dearth of<BR ALIGN='left'/>administrative and judicial attention to<BR ALIGN='left'/>this section of the code.[</TD></TR>
</TABLE>
>]
	qdB3JJyDCF [label=<
