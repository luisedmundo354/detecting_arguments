	ejEBtm2N26 [label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
  <TR><TD BGCOLOR="#add8ff" WIDTH="150"><B>Analysis</B></TD></TR>
  <TR><TD ALIGN="left" WIDTH="150">Here, unlike Southwest Consolidated,<BR ALIGN='left'/>there was merely a shift in the<BR ALIGN='left'/>proprietary interest of the minority<BR ALIGN='left'/>shareholders of Old Aetna. The<BR ALIGN='left'/>transaction here involved cannot be<BR ALIGN='left'/>described accurately as a &quot;sale&quot; of one<BR ALIGN='left'/>corporation&#x27;s assets to another<BR ALIGN='left'/>corporation.</TD></TR>
