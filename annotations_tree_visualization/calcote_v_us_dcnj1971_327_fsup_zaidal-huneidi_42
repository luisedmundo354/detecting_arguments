	"ENq9-QCWLD" [label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
  <TR><TD BGCOLOR="#ffb3b3" WIDTH="150"><B>Conclusion</B></TD></TR>
  <TR><TD ALIGN="left" WIDTH="150">For these reasons, this court concludes<BR ALIGN='left'/>that the transfers in question failed to<BR ALIGN='left'/>qualify as a tax-free reorganization<BR ALIGN='left'/>under § 354 of the Internal Revenue<BR ALIGN='left'/>Code. We need not, accordingly, pass on<BR ALIGN='left'/>the additional grounds raised herein.</TD></TR>
</TABLE>
>]
	"5GRWaHguaB" [label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
  <TR><TD BGCOLOR="#add8ff" WIDTH="150"><B>Analysis</B></TD></TR>
  <TR><TD ALIGN="left" WIDTH="150">Accordingly, this court holds that when<BR ALIGN='left'/>the plaintiff-shareholders of Aero Chem<BR ALIGN='left'/>surrendered their stock in that<BR ALIGN='left'/>corporation, receiving, in effect, the<BR ALIGN='left'/>stock of Pfaudler, they did not retain a<BR ALIGN='left'/>continuing interest in the Aero Chem<BR ALIGN='left'/>assets, but obtained, instead, an<BR ALIGN='left'/>interest in a corporation which enjoyed<BR ALIGN='left'/>a separate and independent existence.[2]</TD></TR>
</TABLE>
>]
